# Render: eazyui-api
# Copy these values into the `eazyui-api` service in Render.

# Render runtime
HOST=0.0.0.0
DATA_DIR=/var/data/eazyui
DATABASE_URL=/var/data/eazyui/eazyui.db

# Public frontend origin for CORS
FRONTEND_URL=https://your-app.vercel.app

# Core AI configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=
GEMINI_IMAGE_FALLBACK_MODEL=

# Optional provider integrations
FIRECRAWL_API_KEY=
FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev/v2
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
NVIDIA_API_KEY=
NVIDIA_MODEL=moonshotai/kimi-k2.5

# API server behavior
API_BODY_LIMIT=26214400
BILLING_PAID_ONLY_OPERATIONS=

# Billing pricing controls
BILLING_CREDITS_PER_USD=100
BILLING_USAGE_MARKUP_MULTIPLIER=3
BILLING_USAGE_MIN_CREDITS=1
BILLING_USAGE_FALLBACK_INPUT_USD_PER_1M=0.8
BILLING_USAGE_FALLBACK_OUTPUT_USD_PER_1M=2.4

# Internal auth bridge to MCP
# If you use `render.yaml`, Render generates INTERNAL_API_KEY for the API service.
INTERNAL_API_KEY=
MCP_API_KEY_PEPPER=

# Firebase Admin
# Prefer one of FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_BASE64.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_STORAGE_BUCKET=

# Analytics and email
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_AUDIENCE_EMAIL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TOPUP_1000=
