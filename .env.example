# EazyUI Environment Variables

# Required: Your Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Firecrawl API key for URL reference scraping
FIRECRAWL_API_KEY=

# Optional: Firecrawl API base URL (defaults to v2 scrape API)
FIRECRAWL_API_BASE_URL=https://api.firecrawl.dev/v2

# Optional: Gemini model to use (default: gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-pro

# Server configuration
PORT=3001
HOST=localhost

# Database (SQLite path)
DATABASE_URL=./data/eazyui.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# PostHog analytics (frontend)
# Replace phc_xxxxxxxxx with your real PostHog project API key.
# Use https://eu.i.posthog.com if your project is hosted in the EU.
VITE_POSTHOG_KEY=phc_xxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phc_xxxxxxxxx
POSTHOG_HOST=https://us.i.posthog.com

# Resend email
# Replace re_xxxxxxxxx with your real Resend API key
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_AUDIENCE_EMAIL=davisdukes18@gmail.com

# Internal server-to-server auth (API <-> MCP bridge)
# Set one strong random value and reuse it for both fields below.
INTERNAL_API_KEY=
MCP_API_KEY_PEPPER=

# Firebase Admin auth verification (API)
# Use one of: FIREBASE_SERVICE_ACCOUNT_JSON or FIREBASE_SERVICE_ACCOUNT_BASE64
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwiLi4u
# Optional but recommended for MCP snapshot uploads
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Stripe billing
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_TEAM_MONTHLY=price_xxx
STRIPE_PRICE_TOPUP_1000=price_xxx

# MCP server
MCP_SERVER_PORT=3010
MCP_SERVER_HOST=0.0.0.0
MCP_ENABLE_MUTATIONS=true
EAZYUI_API_BASE_URL=http://localhost:3001
MCP_REQUIRE_AUTH=true
MCP_DEV_UID=
MCP_INTERNAL_API_KEY=
MCP_FETCH_TIMEOUT_MS=90000
MCP_FETCH_RETRIES=1
