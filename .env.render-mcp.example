# Render: eazyui-mcp-server
# Copy these values into the `eazyui-mcp-server` private service in Render.

MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=3010
MCP_ENABLE_MUTATIONS=true
MCP_REQUIRE_AUTH=true
MCP_DEV_UID=
MCP_FETCH_TIMEOUT_MS=90000
MCP_FETCH_HEAVY_TIMEOUT_MS=420000
MCP_FETCH_RETRIES=1

# API connectivity
# If you use `render.yaml`, Render auto-wires `MCP_INTERNAL_API_KEY` and `EAZYUI_API_HOSTPORT`.
# If you create the service manually instead of using the Blueprint, set EAZYUI_API_BASE_URL yourself.
EAZYUI_API_BASE_URL=
MCP_INTERNAL_API_KEY=

# Firebase Admin
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_STORAGE_BUCKET=
FIREBASE_PROJECT_ID=
